modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["sshpass"]

[[ports]]
localPort = 3999
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 15432
externalPort = 3000
exposeLocalhost = true


[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-gettone-ui-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "inc-sort-ui-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "finplan-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-trigger-date-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "inc-dashboard-authz-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "incentivazione-accservizi-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-timeline-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "admin-authz-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-authz-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-reconcile-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "incentivazione-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-report-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-export-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-validity-gettone-parity-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "brand-gating-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "gara-weights-ui-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "caring-cb-exclusion-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "caring-cb-exclusion-db-tests"

[[workflows.workflow.tasks]]
