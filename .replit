modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["sshpass"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 15432
externalPort = 3000
exposeLocalhost = true


[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "finplan-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-authz-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "cj-reconcile-tests"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "finplan-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-finplan-tests.sh"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "cj-authz-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-customer-journey-authz-tests.sh"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "cj-reconcile-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-customer-journey-reconcile-tests.sh"

[workflows.workflow.metadata]
isValidation = true

[agent]
integrations = ["javascript_log_in_with_replit:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
